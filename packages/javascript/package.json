{
  "name": "@nzr/autofix",
  "version": "0.1.0",
  "description": "NZR Autofix SDK — capture errors and send to NZR Manager for AI-powered diagnosis and auto-fix",
  "license": "MIT",
  "author": "NZR <dev@nzr.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/integrations/react.d.ts",
      "import": "./dist/integrations/react.js",
      "require": "./dist/integrations/react.cjs"
    },
    "./angular": {
      "types": "./dist/integrations/angular.d.ts",
      "import": "./dist/integrations/angular.js",
      "require": "./dist/integrations/angular.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@angular/core": ">=14.0.0",
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  },
  "keywords": [
    "error-tracking",
    "autofix",
    "ai",
    "error-monitoring",
    "debugging",
    "react",
    "angular"
  ]
}
